## Frontend environment (copy to .env.local)

# Base URL of the backend API (FastAPI).
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
BACKEND_URL=http://localhost:8000

# Backend streaming path. If unset, the frontend uses a mock stream so the UI works end-to-end.
# Example: /v1/stream or /stream
BACKEND_STREAM_PATH=/research
