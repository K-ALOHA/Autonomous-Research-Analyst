APP_NAME=autonomous-research-analyst-backend
ENV=local

HOST=0.0.0.0
PORT=8000
BACKEND_PORT=8000
FRONTEND_PORT=3000

LOG_LEVEL=INFO
LOG_JSON=false

# Comma-separated list.
CORS_ALLOW_ORIGINS=http://localhost:3000

# Optional workflow integrations
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost
OPENROUTER_APP_NAME=autonomous-research-analyst
PLANNER_MODEL=deepseek/deepseek-chat
ANALYST_MODEL=deepseek/deepseek-chat
TAVILY_API_KEY=tvly-your-tavily-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_HOST=https://cloud.langfuse.com

# Frontend runtime/proxy config (NEXT_PUBLIC_* are available in browser and server)
BACKEND_URL=http://backend:8000
NEXT_PUBLIC_BACKEND_URL=http://backend:8000
NEXT_PUBLIC_BACKEND_STREAM_PATH=/research
